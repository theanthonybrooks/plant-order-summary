{
  "manifest_version": 3,
  "name": "Nieuwkoop Order Summary",
  "version": "1.2.1",
  "description": "Shows a per-order summary panel: plant / pot / soil counts grouped by species, split by assembled vs not assembled.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Nieuwkoop order summary"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://backend.nieuwkoop-europe.com/*",
    "https://www.nieuwkoop-europe.com/*",
    "https://raw.githubusercontent.com/theanthonybrooks/plant-order-summary/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.nieuwkoop-europe.com/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.nieuwkoop-europe.com/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}
